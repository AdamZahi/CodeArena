# ------------------------------
# Code Arena monorepo .gitignore
# ------------------------------

# Environment and secret files
**/.env
**/.env.*
!**/.env.example
!**/.env.template
!**/.env.sample
.env.example

# Local secret overrides
**/*secret*.yml
**/*secret*.yaml
**/*secret*.properties
**/application-local.yml
**/application-local.yaml
**/application-*.local.yml
**/application-*.local.yaml

# Credentials / keys / certs
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/*.crt
**/*.csr
**/id_rsa
**/id_ed25519

# Secret directories
**/secrets/
**/.secrets/

# Build outputs and dependencies (monorepo safety)
**/target/
**/node_modules/
**/dist/
**/build/
**/.angular/cache/

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / OS
**/.idea/
**/.DS_Store
**/Thumbs.db
# Environment files — contain API keys, never commit these
code-arena-frontend/src/environments/environment.ts
code-arena-frontend/src/environments/environment.prod.ts
